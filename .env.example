# ══════════════════════════════════════════════
# PronoSight — Configuration (template)
# Copie ce fichier en .env et remplis tes clés
# ══════════════════════════════════════════════

# Port du serveur (défaut: 3000)
PORT=3000

# ── IA PRINCIPALE ──────────────────────────────

# Clé API Google Gemini (proxy web search + fallback)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-xxx

# Modèle Gemini par défaut
GEMINI_MODEL=gemini-2.0-flash

# Clé API Groq (fallback Gemini, gratuit)
# https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_xxx

# Clé API Anthropic / Claude (Victor core + generate-picks)
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxx

# ── DONNÉES SPORTIVES ──────────────────────────

# The Odds API — cotes en temps réel (500 req/mois gratuit)
# https://the-odds-api.com → Sign Up
ODDS_API_KEY=

# football-data.org — calendriers et résultats (10 req/min gratuit)
# https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=

# API-Football via RapidAPI — stats, forme, blessures (100 req/jour gratuit)
# https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=

# ── BASE DE DONNÉES ────────────────────────────

# PostgreSQL (Render.com free tier ou local)
# Format : postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/pronosight

# ── BOT TELEGRAM ───────────────────────────────

# Token du bot (créer via @BotFather sur Telegram)
TELEGRAM_BOT_TOKEN=123456789:AAF-xxx

# ID du canal ou groupe de diffusion (ex: @moncanal ou -100xxxxxxxxx)
TELEGRAM_CHANNEL_ID=@pronosight_channel

# ── Clé API interne (protège POST /api/victor/refresh) ──
# Générer avec : node -e "import('crypto').then(c => console.log(c.default.randomBytes(32).toString('hex')))"
VICTOR_API_KEY=
